@model Programa

<div class="container mt-5">

    <div class="text-center mb-4">
        <h1 class="display-5">Atualizador Genérico</h1>
    </div>

    <div class="card shadow">

        <div class="card-header d-flex justify-content-between">
            <h4 class="mb-0">Atualizar Programa</h4>
            <strong>@Model.AppName</strong>
        </div>

        <div class="card-body">

            <form asp-controller="Updater"
                  asp-action="Upload"
                  asp-route-appKeyName="@Model.AppKeyName"
                  method="post"
                  enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input class="form-control"
                           value="@Model.AppName"
                           readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Identificador</label>
                    <input class="form-control"
                           value="@Model.AppKeyName"
                           readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Versão Atual</label>
                    <input class="form-control"
                           value="@Model.Version"
                           readonly />
                </div>

                <div class="mb-4">
                    <label class="form-label">Arquivo (.zip)</label>
                    <input type="file"
                           name="arquivo"
                           class="form-control"
                           accept=".zip"
                           required />
                </div>

                <button type="submit" class="btn btn-success">
                    Publicar Atualização
                </button>

            </form>

        </div>

    </div>

</div>