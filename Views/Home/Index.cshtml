@model List<Programa>


<div class="text-center">
    <h1 class="display-4">Atualizador Genérico</h1>
    <p>Api Status: <strong>ON</strong></p>
</div>

<div class="container mt-4">

    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Nome do Programa</th>
                <th>Versão Atual</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var programa in Model)
            {
                <tr>
                    <td>@programa.Nome</td>
                    <td>@programa.Versao</td>
                </tr>
            }
        </tbody>
    </table>

</div>